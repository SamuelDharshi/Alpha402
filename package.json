{
  "name": "alpha402",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=packages/web",
    "dev:agents": "npm run dev --workspace=packages/agents",
    "dev:bot": "npm run dev --workspace=packages/bot",
    "test:agents": "npm run test --workspace=packages/agents",
    "test:contracts": "npm run test --workspace=packages/contracts",
    "compile": "npm run compile --workspace=packages/contracts",
    "deploy:sepolia": "npm run deploy:sepolia --workspace=packages/contracts"
  },
  "devDependencies": {
    "prettier": "^3.2.5"
  },
  "overrides": {
    "three": "0.158.0",
    "@metamask/sdk": {
      "@react-native-async-storage/async-storage": "$bs58"
    }
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "events": "^3.3.0"
  }
}
